# Anthropic API key for explanation generation (Claude Sonnet 4.6)
ANTHROPIC_API_KEY=

# Twilio account SID (starts with AC...)
TWILIO_ACCOUNT_SID=

# Twilio auth token for WhatsApp webhook HMAC verification and REST auth
TWILIO_AUTH_TOKEN=

# Twilio WhatsApp sender (sandbox default: whatsapp:+14155238886)
TWILIO_FROM_NUMBER=

# Public base URL where Twilio POSTs the inbound webhook (e.g., ngrok or Render URL, no trailing slash)
WEBHOOK_BASE_URL=

# Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key (server-side only — never ship to client)
SUPABASE_KEY=

# Dev-only: set to "true" to bypass HMAC verification (e.g., local curl). NEVER enable in prod.
TWILIO_SKIP_SIGNATURE_VERIFICATION=
